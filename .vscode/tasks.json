{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: uvicorn",
      "type": "shell",
      "command": ".\\venv\\Scripts\\Activate.ps1; uvicorn app.main:app --reload",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "group": "flexinventory",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: npm run dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "panel": "dedicated",
        "group": "flexinventory",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "FlexInventory: iniciar todo",
      "dependsOn": ["Backend: uvicorn", "Frontend: npm run dev"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
